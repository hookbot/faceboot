<?xml version="1.0"?>
<!DOCTYPE cross-domain-policy SYSTEM "http://www.adobe.com/xml/dtds/cross-domain-policy.dtd">
<cross-domain-policy> 
  <allow-access-from domain="cpps.me"   to-ports="80" />
  <allow-access-from domain="*.cpps.me" to-ports="80" />
  <allow-access-from domain="*.cpps.me" to-ports="443" />
  <allow-http-request-headers-from domain="*.cpps.me" headers="*"/>
</cross-domain-policy>
